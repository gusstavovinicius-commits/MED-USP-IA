<script>
const MC={
  simulado:{title:'🩺 Simulado — Casos Clínicos Padrão USP',ph:'Ex: "Caso de cardiologia nível difícil"',btns:[{l:'🫀 Cardio',m:'Gere um caso clínico padrão USP de cardiologia.'},{l:'🧠 Neurologia',m:'Gere um caso clínico padrão USP de neurologia.'},{l:'🫁 Pneumo',m:'Gere um caso padrão USP de pneumologia.'},{l:'🩸 Hemato',m:'Gere um caso padrão USP de hematologia.'},{l:'👶 DNPM/Ped',m:'Gere um caso clínico de DNPM ou triagem neonatal padrão USP.'},{l:'🤰 GO',m:'Gere um caso de pré-eclâmpsia ou HELLP padrão USP.'}],sys:'Você é o Preceptor-Chefe do HCFMUSP especialista em questões de residência USP.'},
  flashcard:{title:'⚡ Flashcards — Notas de Rodapé & Pegadinhas',ph:'Ex: "10 flashcards de cardiologia"',btns:[{l:'⚡ Cardio',m:'10 flashcards de cardiologia focados em pegadinhas USP.'},{l:'⚡ Neuro',m:'10 flashcards de neurologia para A1/MFR.'},{l:'⚡ Hemato',m:'8 flashcards de hematologia com pegadinhas USP.'},{l:'⚡ Eletrólitos',m:'Flashcards sobre distúrbios eletrolíticos.'},{l:'⚡ DNPM',m:'Flashcards sobre desenvolvimento neuropsicomotor.'},{l:'⚡ GO',m:'Flashcards sobre obstetrícia.'}],sys:'Você é o Preceptor-Chefe do HCFMUSP.'},
  revisao:{title:'📖 Revisão Guiada — Protocolos HC-FMUSP',ph:'Digite qualquer tema: "Pericardite"',btns:[{l:'📖 IC',m:'Revisão guiada de Insuficiência Cardíaca FEr.'},{l:'📖 DPOC+VNI',m:'Revisão guiada de DPOC.'},{l:'📖 AVC',m:'Revisão guiada de AVC isquêmico.'},{l:'📖 Falciforme',m:'Revisão guiada de Anemia Falciforme.'},{l:'📖 PE/HELLP',m:'Revisão guiada de Pré-eclâmpsia.'},{l:'📖 Lesão Medular',m:'Revisão guiada de Lesão Medular.'}],sys:'Você é o Preceptor-Chefe do HCFMUSP.'}
};

let curMod='simulado',hist=[],loading=false;
const storage={
  async get(k){
    if(window.storage?.get) return window.storage.get(k);
    return {value:localStorage.getItem(k)};
  },
  async set(k,v){
    if(window.storage?.set) return window.storage.set(k,v);
    localStorage.setItem(k,v);
  },
  async delete(k){
    if(window.storage?.delete) return window.storage.delete(k);
    localStorage.removeItem(k);
  }
};

function go(id,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nitem').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+id)?.classList.add('active');
  el?.classList.add('active');
}

async function loadHist(mod){
  try{const r=await storage.get('hist:'+mod);return r&&r.value?JSON.parse(r.value):[];}catch{return [];}
}
async function saveHist(mod,h){
  try{await storage.set('hist:'+mod,JSON.stringify(h.slice(-40)));}catch(e){console.error('save err',e);}
}
async function clearHist(){
  if(!confirm('Apagar todo o histórico deste módulo?'))return;
  await storage.delete('hist:'+curMod);hist=[];
  document.getElementById('cb').innerHTML=`<div class="msg sys">Histórico limpo · ${MC[curMod].title}</div>`;updateStats();
}

async function setMod(m){
  curMod=m;document.querySelectorAll('.mtab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+m)?.classList.add('active');
  const c=MC[m];document.getElementById('modTitle').textContent=c.title;
  document.getElementById('ci').placeholder=c.ph;
  document.getElementById('qa').innerHTML=c.btns.map((b,i)=>`<button class="qbtn" onclick="sq(${i})">${b.l}</button>`).join('')+'<span class="stats-mini" id="stm"></span>';
  hist=await loadHist(m);const cb=document.getElementById('cb');cb.innerHTML='';
  if(!hist.length){cb.innerHTML=`<div class="msg sys">Módulo ativado: ${c.title}</div>`;}else{cb.innerHTML=`<div class="msg sys">📂 ${hist.length} mensagens restauradas · ${c.title}</div>`;hist.forEach(msg=>renderMsg(msg.role,msg.content,true));}
  updateStats();
}
function updateStats(){const stm=document.getElementById('stm');if(!stm)return;const u=hist.filter(h=>h.role==='user').length;stm.innerHTML=`<b>${u}</b> perguntas · <b>${hist.length}</b> msgs salvas`;}
function sq(i){document.getElementById('ci').value=MC[curMod].btns[i].m;send();}
function hk(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}}
function ar(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,110)+'px';}
function escapeHtml(value){return value.replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;');}

async function runAi(prompt){
  if(typeof window.claude?.complete==='function') return window.claude.complete(prompt);
  if(typeof window.OPENAI_API_KEY==='string'&&window.OPENAI_API_KEY){
    const res=await fetch('https://api.openai.com/v1/responses',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+window.OPENAI_API_KEY},body:JSON.stringify({model:'gpt-4.1-mini',input:prompt})});
    if(!res.ok) throw new Error(`OpenAI HTTP ${res.status}`);
    const data=await res.json();
    return data.output_text || 'Sem resposta textual.';
  }
  return '⚠️ Nenhuma integração de IA configurada.\n\nPara publicar: use dentro do Claude (window.claude.complete) **ou** defina `window.OPENAI_API_KEY` antes de enviar mensagens.\n\nExemplo no console:\n`window.OPENAI_API_KEY = "sua-chave"`';
}

async function send(){
  const inp=document.getElementById('ci');const txt=inp.value.trim();if(!txt||loading)return;
  inp.value='';inp.style.height='auto';loading=true;document.getElementById('sb').disabled=true;
  renderMsg('user',txt);hist.push({role:'user',content:txt});const tid=addTyping();
  try{
    const ctx=hist.slice(0,-1).slice(-8).map(m=>(m.role==='user'?'P: ':'R: ')+m.content.slice(0,500)).join('\n');
    const prompt=`${MC[curMod].sys}\n\n${ctx?`Contexto anterior:\n${ctx}\n\n`:''}Pergunta do estudante de medicina:\n${txt}`;
    const resp=await runAi(prompt);removeTyping(tid);
    if(resp&&typeof resp==='string'&&resp.trim()){
      hist.push({role:'assistant',content:resp});
      let render=resp;
      if(render.includes('||GABARITO||')){const [body,gab]=render.split('||GABARITO||');render=body+`\n<button class="abtn" onclick="this.nextElementSibling.style.display='block';this.style.display='none'">👁 Revelar Gabarito & Explicação</button><span style="display:none">${gab}</span>`;}
      renderMsg('assistant',render);await saveHist(curMod,hist);updateStats();
    } else renderMsg('assistant','⚠️ Resposta vazia da API.');
  }catch(e){removeTyping(tid);renderMsg('assistant',`⚠️ Exceção: ${escapeHtml(e.message||String(e))}`);}finally{loading=false;document.getElementById('sb').disabled=false;document.getElementById('ci').focus();}
}

function renderMsg(role,text,skipScroll){
  const cb=document.getElementById('cb');const d=document.createElement('div');d.className='msg '+role;
  if(role==='assistant'){
    const safe=escapeHtml(text)
      .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
      .replace(/`(.+?)`/g,'<code>$1</code>')
      .replace(/^### (.+)$/gm,'<h3>$1</h3>')
      .replace(/^#### (.+)$/gm,'<h4>$1</h4>')
      .replace(/^---$/gm,'<hr>')
      .replace(/\n/g,'<br>');
    d.innerHTML=safe;
  } else d.textContent=text;
  cb.appendChild(d);if(!skipScroll)cb.scrollTop=cb.scrollHeight;
}
let tc=0;
function addTyping(){const cb=document.getElementById('cb');const id='t'+(++tc);const d=document.createElement('div');d.id=id;d.className='typing';d.innerHTML='<div class="td"></div><div class="td"></div><div class="td"></div>';cb.appendChild(d);cb.scrollTop=cb.scrollHeight;return id;}
function removeTyping(id){document.getElementById(id)?.remove();}
function toggleTheme(){document.body.classList.toggle('light');document.querySelector('.thbtn').textContent=document.body.classList.contains('light')?'🌙':'☀';}
setMod('simulado');
</script>
</body>
</html>
