  <div class="ptitle" id="modTitle">Módulos de Estudo — IA Integrada</div>
  <div class="psub">Claude/OpenAI/Local · Padrão USP · Protocolos HC-FMUSP · <span style="color:var(--green)">● Progresso salvo automaticamente</span></div>
  <div class="mtabs"><div class="mtab active" id="tab-simulado" onclick="setMod('simulado')">🩺 Simulado USP</div><div class="mtab" id="tab-flashcard" onclick="setMod('flashcard')">⚡ Flashcards</div><div class="mtab" id="tab-revisao" onclick="setMod('revisao')">📖 Revisão Guiada</div></div>
  <div class="qa" id="qa"></div>
  <div class="card" style="padding:0;overflow:hidden"><div class="chatbox" id="cb" style="padding:12px 14px"></div></div>
  <div class="cirow"><textarea class="ci" id="ci" rows="1" onkeydown="hk(event)" oninput="ar(this)"></textarea><button class="clrbtn" onclick="clearHist()" title="Limpar histórico deste módulo">🗑</button><button class="sbtn" id="sb" onclick="send()">Enviar →</button></div>
